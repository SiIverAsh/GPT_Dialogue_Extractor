{
  "manifest_version": 3,
  "name": "GPT Dialogue Extractor",
  "short_name": "GPT Extractor",
  "version": "0.2.0",
  "description": "Export the current ChatGPT conversation as JSON, Markdown, or PDF from the live page DOM.",
  "permissions": ["downloads"],
  "background": {
    "service_worker": "src/background/index.js"
  },
  "host_permissions": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": [
        "src/content/binary-utils.js",
        "src/content/page-bridge.js",
        "src/content/formula-copy.js",
        "src/content/pdf-export.js",
        "src/content/formatters.js",
        "src/content/download-bridge.js",
        "src/content/index.js"
      ],
      "css": ["src/content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/page-hook.js"],
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"]
    }
  ]
}
